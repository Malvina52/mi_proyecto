+from __future__ import annotations
+
+from crewai.tools import tool
+from playwright.sync_api import TimeoutError as PlaywrightTimeoutError
+from playwright.sync_api import sync_playwright
+
+
+PORTAL_JURISPRUDENCIA_ER = "https://jur.jusentrerios.gov.ar/jur/?ai=jur||newpublica"
+
+
+def _recortar_texto(texto: str, limite: int = 6000) -> str:
+    texto = " ".join(texto.split())
+    if len(texto) <= limite:
+        return texto
+    return texto[:limite] + "... [contenido recortado]"
+
+
+@tool("herramienta_busqueda_jurisprudencia_er")
+def buscar_jurisprudencia_publica(termino: str) -> str:
+    """
+    Busca jurisprudencia en el portal público de Entre Ríos.
+
+    Seguridad:
+    - No resuelve CAPTCHAs automáticamente.
+    - Si el sitio solicita CAPTCHA, el navegador queda visible para que lo
+      resuelva una persona.
+    - Devuelve texto resumido de la página para que el agente lo analice.
+    """
+    if not termino or not termino.strip():
+        return "No se recibió un término de búsqueda válido."
+
+    termino = termino.strip()
+
+    with sync_playwright() as p:
+        browser = p.chromium.launch(headless=False)
+        context = browser.new_context()
+        page = context.new_page()
+
+        try:
+            page.goto(PORTAL_JURISPRUDENCIA_ER, wait_until="networkidle", timeout=60000)
+
+            try:
+                campo_sumario = page.locator("input[name='sumario']").first
+                campo_sumario.wait_for(state="visible", timeout=15000)
+            except PlaywrightTimeoutError:
+                return (
+                    "El portal no mostró el campo de búsqueda. "
+                    "Puede requerir CAPTCHA o intervención manual. "
+                    "Abrí el navegador visible, resolvé el paso solicitado y "
+                    "volvé a ejecutar la búsqueda."
+                )
+
+            campo_sumario.fill(termino)
+            page.keyboard.press("Enter")
+            page.wait_for_load_state("networkidle", timeout=60000)
+
+            contenido = page.inner_text("body")
+            return _recortar_texto(contenido)
+
+        except Exception as exc:
+            return (
+                "No se pudo completar la búsqueda de jurisprudencia. "
+                f"Detalle técnico: {type(exc).__name__}: {exc}"
+            )
+        finally:
+            browser.close()
